# Supabase (required for auth and profiles)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Backend API URL (required for OTP verification, forgot password, etc.)
EXPO_PUBLIC_API_URL=http://localhost:3001

# Google Sign-In (native dev build / production — not Expo Go)
# Web client ID (OAuth 2.0 client type "Web application" in Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS OAuth client ID from Google Cloud (iOS application type)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# URL scheme for iOS (from Google iOS client id: 123-xyz.apps.googleusercontent.com → com.googleusercontent.apps.123-xyz)
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# Expo push (iOS): project ID from https://expo.dev → your project → Project settings → Project ID (or `eas init`).
# Required for getExpoPushTokenAsync in a dev/production build (not Expo Go).
EXPO_PUBLIC_EAS_PROJECT_ID=

# Apple: enable the Apple provider in Supabase; enable Sign in with Apple capability on the App ID and in Xcode.
# Optional — generate JWT for Supabase Apple "Secret Key" (dashboard often requires it): yarn generate-apple-jwt
# Never commit .p8 keys. Use an absolute path or path relative to project root.
APPLE_P8_PATH=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Optional; defaults to expo.ios.bundleIdentifier in app.json (must match Supabase Client IDs).
# APPLE_CLIENT_ID=
# APPLE_JWT_EXPIRES_IN=180d
